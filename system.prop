# Hardware
ro.mediatek.platform=MT6785
ro.hardware=mt6785

# TEE
ro.vendor.mtk_tee_gp_support=1
ro.vendor.mtk_microtrust_tee_support=1

# Crypto FBE / FBEv2
fbe.metadata.wrappedkey=true
ro.crypto.volume.filenames_mode=aes-256-cts
ro.crypto.dm_default_key.options_format.version=2
ro.crypto.volume.metadata.method=dm-default-key
ro.crypto.volume.options=::v2

# Beanpod Hardware
ro.hardware.kmsetkey=beanpod
ro.hardware.gatekeeper=beanpod

# Prefix Fstab
ro.postinstall.fstab.prefix=/system

# USB
ro.sys.usb.storage.type=mtp

# Build ID default
ro.system.build.id=RP1A.200720.011
